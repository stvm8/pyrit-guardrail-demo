# Copy this to .env and fill in your values
# cp .env.example .env

# ── Required for LLM judge scoring (PyRIT uses this to evaluate responses) ──
# Without this, tests fall back to a regex scorer (less accurate but functional)
OPENAI_API_KEY=sk-...

# ── Demo app settings ──
APP_AUTH_TOKEN=demo-secret-token-123
APP_ENDPOINT=http://localhost:8000

# ── Guardrail mode for the demo app ──
# "strong" → tests should PASS
# "weak"   → tests should FAIL (demonstrates CI blocking)
GUARDRAIL_STRENGTH=strong
